
# ==========================================
# Archivo: ../k8s/infra/fluent-bit/clusterole.yaml
# ==========================================
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: fluent-bit-read
rules:
- apiGroups: [""]
  resources: ["namespaces", "pods"]
  verbs: ["get", "list", "watch"]
---


# ==========================================
# Archivo: ../k8s/infra/fluent-bit/clusterrolebinding.yaml
# ==========================================

apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: fluent-bit-read
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: fluent-bit-read
subjects:
- kind: ServiceAccount
  name: fluent-bit
  namespace: infra
---


# ==========================================
# Archivo: ../k8s/infra/fluent-bit/configmap.yaml
# ==========================================
apiVersion: v1
kind: ConfigMap
metadata:
  name: fluent-bit-config
  namespace: infra
data:
  fluent-bit.conf: |
    [SERVICE]
        Flush         1
        Log_Level     info
        Daemon        off
        Parsers_File  parsers.conf

    [INPUT]
        Name              tail
        Tag               kube.*
        Path              /var/log/containers/*.log
        Parser            cri
        DB                /var/log/flb_kube.db
        Mem_Buf_Limit     5MB
        Skip_Long_Lines   On

    [FILTER]
        Name                kubernetes
        Match               kube.*
        Kube_URL            https://kubernetes.default.svc:443
        Kube_CA_File        /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
        Kube_Token_File     /var/run/secrets/kubernetes.io/serviceaccount/token
        Kube_Tag_Prefix     kube.var.log.containers.
        Merge_Log           On

    # --- NUEVO FILTRO PARA EXCLUIR RUIDO ---
    [FILTER]
        Name    grep
        Match   kube.*
        # Excluimos explícitamente los namespaces del sistema
        Exclude $kubernetes['namespace_name'] ^(kube-system|local-path-storage|ingress-nginx)$
        
        # Alternativamente, si solo quisieras INCLUIR estrictamente tus 4 namespaces, 
        # borrarías la línea de arriba y usarías esta (descomentándola):
        # Regex $kubernetes['namespace_name'] ^(apis|blockchain|infra|frontend)$

    [OUTPUT]
            Name        loki
            Match       *
            Host        loki.infra.svc.cluster.local
            Port        3100
            Labels      job=fluentbit, namespace=$kubernetes['namespace_name'], pod=$kubernetes['pod_name']

---


# ==========================================
# Archivo: ../k8s/infra/fluent-bit/daemonset.yaml
# ==========================================
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: fluent-bit
  namespace: infra
  labels:
    app: fluent-bit
spec:
  selector:
    matchLabels:
      app: fluent-bit
  template:
    metadata:
      labels:
        app: fluent-bit
    spec:
      serviceAccountName: fluent-bit
      containers:
      - name: fluent-bit
        image: cr.fluentbit.io/fluent/fluent-bit:3.0.0
        volumeMounts:
        - name: varlog
          mountPath: /var/log
        - name: fluent-bit-config
          mountPath: /fluent-bit/etc/
      volumes:
      - name: varlog
        hostPath:
          path: /var/log
      - name: fluent-bit-config
        configMap:
          name: fluent-bit-config
---


# ==========================================
# Archivo: ../k8s/infra/fluent-bit/serviceaccount.yaml
# ==========================================
apiVersion: v1
kind: ServiceAccount
metadata:
  name: fluent-bit
  namespace: infra
---

